@model List<UserViewModel>

<div class="container mt-4">
    <h2 class="mb-4">Gerenciar Usuários</h2>

    <form method="get" class="mb-3 d-flex">
        <input type="text" name="search" class="form-control me-2" placeholder="Buscar por email" />
        <button type="submit" class="btn btn-primary">Buscar</button>
    </form>

    <div class="row">
        @foreach (var user in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@user.Email</h5>

                        <p>
                            <span class="badge @(user.IsAdmin ? "bg-success" : "bg-secondary")">
                                @(user.IsAdmin ? "Admin" : "Paciente")
                            </span>
                        </p>

                        <a asp-action="ToggleAdmin"
                               asp-route-id="@user.Id"
                               class="btn @(user.IsAdmin ? "btn-danger" : "btn-success") btn-sm">
                            @(user.IsAdmin ? "Remover Admin" : "Tornar Admin")
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>