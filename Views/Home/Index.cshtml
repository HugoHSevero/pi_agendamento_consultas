@if (!User.Identity.IsAuthenticated)
{
    <div class="container text-center mt-5">

        <h1 class="mb-3">Sistema de chamados</h1>

        <p class="lead mb-4">
            Gerencie solicitações e suporte de forma simples e eficiente.
            <br>
            Abra, acompanhe e resolva chamados com organização e agilidade.
        </p>

        <a href="/Identity/Account/Login" class="btn btn-primary me-2">
            Entrar
        </a>

        <a href="/Identity/Account/Register" class="btn btn-outline-primary">
            Criar conta
        </a>

        <p class="text-muted mt-4">
            Projeto Integrador desenvolvido para a UNIVESP, com foco em desenvolvimento web e gestão de chamados.
        </p>

    </div>
} 
else
{
    <div class="container mt-4">

        <h2>Bem-vindo, @User.Identity.Name!</h2>
        <p class="text-muted">
            Aqui você pode abrir e acompanhar os seus chamados.
        </p>

        <div class="row mt-4">

            <div class="col-md-4">
                <div class="card shadow h-100 text-center p-3">
                    <h5>Abrir Chamado</h5>
                    <p>Criar uma nova solicitação</p>
                    <a href="/Chamados/Create" class="btn btn-primary">Abrir</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow h-100 text-center p-3">
                    <h5>Meus Chamados</h5>
                    <p>Visualizar seus chamados</p>
                    <a href="/Chamados" class="btn btn-success">Ver</a>
                </div>
            </div>
            
            @if (User.IsInRole("Admin"))
            {
                <div class="col-md-4">
                    <div class="card shadow h-100 text-center p-3">
                        <h5>Administração</h5>
                        <p>Gerenciar usuários e chamados</p>
                        <a href="/Admin" class="btn btn-dark">Acessar</a>
                    </div>
                </div>
            }

        </div>

    </div>
}

<style>
    .card:hover {
        transform: scale(1.02);
        transition: 0.2s;
        cursor: pointer;
    }
</style>