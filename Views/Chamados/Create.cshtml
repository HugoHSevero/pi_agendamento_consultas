@model Chamado

<div class="container mt-5">
    <h2>Abrir Chamado</h2>

    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label>Título</label>
            <input asp-for="Titulo" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Descrição</label>
            <textarea asp-for="Descricao" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label>Categoria</label>
            <select asp-for="Categoria" class="form-control"
                    asp-items="Html.GetEnumSelectList<CategoriaChamado>()">
            </select>
        </div>
        
        <div class="mb-3">
            <label>Prioridade</label>
            <select asp-for="Prioridade" class="form-control"
                    asp-items="Html.GetEnumSelectList<PrioridadeChamado>()">
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Criar</button>
    </form>
</div>