@model Chamado

<div class="container mt-5">
    <h2>@Model.Titulo</h2>

    <p>@Model.Descricao</p>

    <p><strong>Status:</strong> @Model.Status</p>
    <p><strong>Categoria:</strong> @Model.Categoria</p>
    <p><strong>Data:</strong> @Model.DataCriacao</p>

    @if (User.IsInRole("Admin"))
    {
        <p><strong>Usuário:</strong> @Model.Usuario?.Email</p>
    }
    
    @if (User.IsInRole("Admin"))
    {
        <form asp-action="AlterarStatus" method="post" class="mt-3">

            <input type="hidden" name="id" value="@Model.Id" />

            <select name="status" class="form-control mb-2"
                    asp-items="Html.GetEnumSelectList<StatusChamado>()">
            </select>

            <button type="submit" class="btn btn-warning">
                Alterar Status
            </button>
        </form>
    }

    <a href="/Chamados" class="btn btn-secondary mt-3">Voltar</a>
</div>